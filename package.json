{
  "name": "lead-generation-crm",
  "version": "1.0.0",
  "description": "Local lead generation CRM for business outreach in Zürich",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "test": "jest --verbose --testPathIgnorePatterns=e2e",
    "test:e2e:preview": "jest tests/previewBuild.e2e.test.js --testTimeout=120000 --runInBand",
    "install-browsers": "npx playwright install chromium"
  },
  "dependencies": {
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "playwright": "1.49.1",
    "uuid": "^11.0.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "fast-check": "^4.8.0",
    "jest": "29.7.0"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/?(*.)+(spec|test|property).[jt]s?(x)"
    ]
  },
  "keywords": [],
  "license": "UNLICENSED",
  "private": true
}
